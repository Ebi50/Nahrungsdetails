# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# Nur serverseitig (Cache-Writes, oauth_tokens) — niemals im Frontend!
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# USDA FoodData Central (kostenloser Key: https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=<usda-api-key>

# Strava (Phase 2) — Server-Env, optional bis OAuth gebaut wird
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
